POSTGRES_USER=messenger
POSTGRES_PASSWORD=messenger
POSTGRES_DB=messenger

DATABASE_URL=postgres://messenger:messenger@postgres:5432/messenger?sslmode=disable
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
HTTP_ADDR=:8080
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

FRONTEND_PORT=80

# WebSocket Origin (опционально). Пусто — разрешены все Origin (только для dev/LAN).
# Пример для доступа с других устройств: http://192.168.1.10,http://192.168.1.10:5173
# WS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173
